# ─── REQUIRED — fill ALL of these before deploying ───────────────────────────

# Your domain (no https://, no trailing slash) — must match SSL + Meta webhook host (e.g. betteraisender.com)
DOMAIN=your-domain.com

# PostgreSQL
POSTGRES_DB=whatsapp_crm
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password_here

# Redis
REDIS_PASSWORD=CHANGE_ME_strong_redis_password_here

# JWT — generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_64_char_random_string_here
JWT_REFRESH_SECRET=CHANGE_ME_another_64_char_random_string

# AES encryption key — must be exactly 32 characters
ENCRYPTION_KEY=CHANGE_ME_exactly_32_chars_here_!

# ─── WhatsApp ─────────────────────────────────────────────────────────────────
WHATSAPP_WEBHOOK_VERIFY_TOKEN=CHANGE_ME_your_webhook_verify_token
# Must match Meta “App secret” exactly (no quotes/spaces). If wrong → logs “Invalid webhook signature” and no inbound msgs. Leave empty to skip check (testing only).
WHATSAPP_APP_SECRET=
# Optional: public site URL with https (defaults to https://$DOMAIN via docker-compose FRONTEND_URL)
# PUBLIC_URL=https://betteraisender.com
WHATSAPP_API_VERSION=v19.0

# ─── OpenAI (AI features) ────────────────────────────────────────────────────
OPENAI_API_KEY=                         # sk-...

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# ─── Google OAuth (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Payments (optional) ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=

# ─── Docker image tags ────────────────────────────────────────────────────────
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_BACKEND=YOUR_GITHUB_USERNAME/whatsapp-crm-backend
DOCKER_IMAGE_FRONTEND=YOUR_GITHUB_USERNAME/whatsapp-crm-frontend
IMAGE_TAG=latest
